# SOVEREIGN Configuration Example
# Rename this file to .env or edit config/sovereign.toml

# Choose your brain: "ollama" or "gemini"
SOVEREIGN_PROVIDER=gemini

# If using Gemini (Free Tier)
SOVEREIGN_API_KEY=your_gemini_api_key_here

# If using Ollama (Local)
SOVEREIGN_OLLAMA_URL=http://localhost:11434
SOVEREIGN_MODEL=mistral-nemo
